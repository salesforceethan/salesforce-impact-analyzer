<?xml version="1.0" encoding="UTF-8"?>
<Package xmlns="http://soap.sforce.com/2006/04/metadata">

    <!-- Apex + Triggers -->
    <types>
        <members>*</members>
        <name>ApexClass</name>
    </types>
    <types>
        <members>*</members>
        <name>ApexTrigger</name>
    </types>

    <!-- Flows -->
    <types>
        <members>*</members>
        <name>Flow</name>
    </types>
    <types>
        <members>*</members>
        <name>FlowDefinition</name>
    </types>

    <!-- Objects + Fields + Validation Rules + Sharing Rules
         (validationRules/ and sharingRules/ are retrieved as part of CustomObject metadata) -->
    <types>
        <members>*</members>
        <name>CustomObject</name>
    </types>

    <!-- Workflow (older automation + field references) -->
    <types>
        <members>*</members>
        <name>Workflow</name>
    </types>

    <!-- Rules often reference fields, owners, queues -->
    <types>
        <members>*</members>
        <name>AssignmentRules</name>
    </types>
    <types>
        <members>*</members>
        <name>AutoResponseRules</name>
    </types>
    <types>
        <members>*</members>
        <name>EscalationRules</name>
    </types>

    <!-- Permissioning (lots of field/object references) -->
    <types>
        <members>*</members>
        <name>PermissionSet</name>
    </types>
    <types>
        <members>*</members>
        <name>PermissionSetGroup</name>
    </types>
    <types>
        <members>*</members>
        <name>CustomPermission</name>
    </types>

    <!-- UI / Components -->
    <types>
        <members>*</members>
        <name>LightningComponentBundle</name>
    </types>
    <types>
        <members>*</members>
        <name>AuraDefinitionBundle</name>
    </types>
    <types>
        <members>*</members>
        <name>FlexiPage</name>
    </types>
    <types>
        <members>*</members>
        <name>Layout</name>
    </types>

    <!-- Reporting (filters often reference fields) -->
    <types>
        <members>*</members>
        <name>Report</name>
    </types>
    <types>
        <members>*</members>
        <name>Dashboard</name>
    </types>
    <types>
        <members>*</members>
        <name>ReportType</name>
    </types>

    <!-- Email templates + text templates (often reference merge fields) -->
    <types>
        <members>*</members>
        <name>EmailTemplate</name>
    </types>

    <!-- Picklists + shared value sets (can affect flows/validations) -->
    <types>
        <members>*</members>
        <name>GlobalValueSet</name>
    </types>
    <types>
        <members>*</members>
        <name>GlobalValueSetTranslation</name>
    </types>

    <!-- Misc “often referenced” -->
    <types>
        <members>*</members>
        <name>CustomMetadata</name>
    </types>
    <types>
        <members>*</members>
        <name>CustomLabel</name>
    </types>
    <types>
        <members>*</members>
        <name>NamedCredential</name>
    </types>
    <types>
        <members>*</members>
        <name>RemoteSiteSetting</name>
    </types>

    <version>65.0</version>
</Package>
